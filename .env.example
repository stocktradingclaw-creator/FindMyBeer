# Copy to .env.local and fill in.

# Claude API key from https://platform.claude.com (powers scans + rating lookups)
ANTHROPIC_API_KEY=

# Session signing secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Neon Postgres connection string (https://neon.tech, free tier).
# Without it the app still works, but accounts/sign-up are disabled and
# profiles/history stay on-device.
DATABASE_URL=

# Optional: Google sign-in (https://console.cloud.google.com → OAuth credentials).
# Leave blank to offer email+password only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
